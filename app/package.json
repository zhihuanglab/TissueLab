{
    "name": "TissueLab",
    "version": "1.0.2",
    "description": "Advancing digital pathology analysis for medical professionals and researchers",
    "author": {
        "name": "Huang Group",
        "email": "zhi.huang@pennmedicine.upenn.edu"
    },
    "main": "electron/main.js",
    "scripts": {
        "start": "npm run start-electron",
        "start:prod": "cross-env FORCE_PRODUCTION=true electron .",
        "dev": "concurrently --kill-others \"npm run start-electron-dev\" \"npm run start-frontend\"",
        "build": "node build-render.js",
        "start-electron": "electron .",
        "start-electron-dev": "electron electron/main_electron.js",
        "start-frontend": "cd render && npm run dev",
        "start-backend": "cd service && python main.py",
        "build-exec": "npx electron-packager . TissueLab --platform=win32 --arch=x64 --icon=TissueLab_logo.ico --out=release-builds --overwrite --ignore=render/node_modules --ignore=render/.next",
        "dist:win": "electron-builder --win",
        "dist:mac": "electron-builder --mac",
        "test": "cd render && npm run build && cd .. && npm start",
        "testall": "conda activate tissuelab && pip install -r ../requirements.txt && npm install && cd render && npm install && npm run build && cd .. && npm start"
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "electron": "41.0.2",
        "electron-builder": "^26.8.1",
        "electron-is-dev": "^3.0.1",
        "@electron/notarize": "^3.1.1",
        "@electron/packager": "^19.1.0"
    },
    "dependencies": {
        "cors": "^2.8.6",
        "express": "^5.2.1",
        "http-proxy-middleware": "^3.0.5"
    },
    "build": {
        "includeSubNodeModules": true,
        "extraMetadata": {
            "description": "TissueLab"
        },
        "asar": true,
        "appId": "com.zhihuanglab.tissuelab",
        "files": [
            "electron/**/*",
            "TissueLab_logo.ico",
            "package.json",
            "render/.next/standalone/**/*",
            "!service/__pycache__/**/*",
            "!service/build/**/*",
            "!service/dist/**/*",
            "!service/storage/**/*",
            "!example_WSI/**/*",
            "!**/.git/**/*",
            "!**/.gitignore",
            "!**/README.md",
            "!**/LICENSE",
            "!**/package-lock.json",
            "!**/yarn.lock",
            "!**/tsconfig.json",
            "!**/tsconfig.tsbuildinfo",
            "!**/*.md",
            "!**/test/**/*",
            "!**/tests/**/*",
            "!**/spec/**/*",
            "!**/docs/**/*",
            "!**/examples/**/*",
            "!render/node_modules/**/*",
            "!render/.next/cache/**/*"
        ],
        "asarUnpack": [
            "**/*.dylib",
            "**/*.so",
            "**/*.dll",
            "**/*.node",
            "electron/assets/TissueLab_AI/**/*",
            "render/.next/standalone/**/*"
        ],
        "win": {
            "target": "nsis",
            "icon": "TissueLab_logo.ico",
            "requestedExecutionLevel": "asInvoker"
        },
        "mac": {
            "target": "dmg",
            "icon": "electron/assets/icons/icon.icns",
            "category": "public.app-category.developer-tools",
            "hardenedRuntime": true,
            "gatekeeperAssess": false,
            "entitlements": "electron/assets/entitlements.mac.plist",
            "entitlementsInherit": "electron/assets/entitlements.mac.plist"
        },
        "dmg": {
            "title": "TissueLab",
            "icon": "electron/assets/icons/icon.icns",
            "background": "electron/assets/dmg-background.png",
            "window": {
                "width": 540,
                "height": 380
            },
            "contents": [
                {
                    "x": 120,
                    "y": 180,
                    "type": "file"
                },
                {
                    "x": 420,
                    "y": 180,
                    "type": "link",
                    "path": "/Applications"
                }
            ],
            "iconSize": 160,
            "iconTextSize": 14
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "allowElevation": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "TissueLab",
            "artifactName": "TissueLab-Setup-${version}.${ext}",
            "deleteAppDataOnUninstall": false
        }
    }
}
