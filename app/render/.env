# ==== Google Auth ====
# Google OAuth 2.0 "Desktop app" client used by the Electron OAuth flow.
# Per Google's installed-app flow, the token exchange request requires
# client_secret to be sent alongside the PKCE code_verifier:
#   https://developers.google.com/identity/protocols/oauth2/native-app
# Because the binary must ship this value to perform the exchange, it
# cannot remain confidential in practice — see RFC 8252 §8.5
# (https://datatracker.ietf.org/doc/html/rfc8252#section-8.5):
#   "Secrets that are statically included as part of an app distributed to
#    multiple users should not be treated as confidential secrets."
# The security boundary here is the registered loopback redirect_uri plus
# Firebase Auth rules, not the secrecy of this value.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=739177350163-oh1tjch4hfp6k4c0qn1no83mpqbkobk5.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_SECRET=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

# ==== Debug ====
DEBUG_ENV=local
