# Local backend, cloud ctrl service, tissuelab-2025 Firebase project
PUBLIC_AI_SERVICE_HOST = 127.0.0.1
PUBLIC_AI_SERVICE_SOCKET_ENDPOINT = ws://${PUBLIC_AI_SERVICE_HOST}:5001/ws
PUBLIC_AI_SERVICE_API_ENDPOINT = http://${PUBLIC_AI_SERVICE_HOST}:5001/api
PUBLIC_CTRL_SERVICE_HOST = ctrl.vlm.ai
PUBLIC_CTRL_SERVICE_API_ENDPOINT = https://ctrl.vlm.ai/api

# Local LLM agent (TissueLab AI service exposes /api/agent/*); fall back to cloud ctrl service if unset.
PUBLIC_AGENT_API_ENDPOINT = http://${PUBLIC_AI_SERVICE_HOST}:5001/api

# ==== Behavior Logging Config ====
NEXT_PUBLIC_MOUSE_TRACKING_HZ = 10
NEXT_PUBLIC_VIEWPORT_TRACKING_HZ = 10
NEXT_PUBLIC_ENABLE_BEHAVIOR_CONSOLE_LOGS = true

